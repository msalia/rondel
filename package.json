{
  "name": "circular-code",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && node scripts/resolve-aliases.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-dataset": "rm -rf dataset/images dataset/labels dataset/data.yaml && node dist/scripts/generateDataset.js",
    "train": "bash training/setup_venv.sh && training/venv/bin/python training/train.py && training/venv/bin/python training/export.py",
    "export-model": "training/venv/bin/python training/export.py",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'scripts/**/*.ts'",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts' 'scripts/**/*.ts'",
    "example:build": "node example/build.js",
    "example": "node example/build.js && node example/serve.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "eslint": "^10.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "canvas": "^3.2.3",
    "react": "^19.2.5"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
